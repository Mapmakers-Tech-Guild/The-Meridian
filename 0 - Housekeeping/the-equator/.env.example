# Required
DISCORD_TOKEN=your-bot-token-here
DISCORD_GUILD_ID=1413635934012047414

# Path to the root of The-Meridian KB repo.
# Defaults to "../" (assumes the-equator is cloned next to The-Meridian).
KB_PATH=../

# Optional: comma-separated channel IDs to ignore (e.g. spam, bots)
# IGNORE_CHANNEL_IDS=

# Set to "true" to run a full historical export on bot startup
# EXPORT_ON_START=false
